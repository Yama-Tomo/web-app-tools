{
  "name": "@yamatomo/web-app-tools",
  "private": true,
  "scripts": {
    "prepare": "pnpm build",
    "build": "pnpm --aggregate-output -F='./packages/*' build",
    "test": "pnpm --aggregate-output -F='./packages/*' --parallel test",
    "lint": "biome ci",
    "lint:fix": "biome check --write",
    "typecheck": "pnpm --aggregate-output -F='./packages/*' --parallel typecheck"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^6.0.2"
    }
  }
}
